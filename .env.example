# Telegram Bot Token (получи у @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...

# Telegram ID администраторов через запятую.
# Узнать свой ID: напиши @userinfobot в Telegram.
# Эти юзеры получают заявки на доступ и могут одобрять/блокировать.
ADMIN_IDS=123456789

# Модель генерации изображений
IMAGE_MODEL=gpt-image-2

# Модель чата по умолчанию (можно сменить через меню в боте)
DEFAULT_TEXT_MODEL=gpt-5-mini

# Сколько последних сообщений из истории передавать в OpenAI
HISTORY_LIMIT=20

# Путь к SQLite БД.
# Локально: ./data/bot.db
# На Railway с volume: /data/bot.db (volume монтируется в /data)
DB_PATH=./data/bot.db

# Уровень логов: trace | debug | info | warn | error
LOG_LEVEL=info
